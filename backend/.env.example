# Copy this file to .env and fill in real values.  NEVER commit the real .env.
# NOTE: keep comments on their OWN lines. Inline comments after a value
#       (e.g. KEY=value  # note) are parsed as PART of the value.

# ── PostgreSQL ──
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://agripulse:agripulse@localhost:5432/agripulse

# ── JWT ──
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_long_random_string
# 24h
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── External services ──
# the ai_service FastAPI (ML models)
AI_SERVICE_URL=http://localhost:8001
# e.g. OpenWeatherMap key (optional)
WEATHER_API_KEY=

# ── OpenAI (GPT assistant) ──
# When set, the "Ask Assistant" chat answers come from GPT; otherwise the
# local FLAN-T5 model (ai_service on :8001) answers. Leave blank to use local.
# Get a key at https://platform.openai.com/api-keys (format: sk-...).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
